# gRPC 服務監聽的本地位址
GRPC_PORT=:50051

# HTTP REST API 監聽位址
HTTP_PORT=:8081

# JWT 認證密鑰
JWT_SECRET=super-secret-key

# PostgreSQL 資料庫配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=secra

# PostgreSQL 主機名稱
# Docker 環境：使用 db (服務名稱，內部網路)
# 本地開發：使用 localhost
POSTGRES_HOST=db
POSTGRES_PORT=5432

# 自動執行資料庫 Migration (default: true)
# 設為 false 時需要手動執行: docker compose exec server secra migrate up
AUTO_MIGRATE=true

# NVD API 配置
NVD_URL_V1=https://nvd.nist.gov/feeds/json/cve/1.1/
NVD_URL_V2=https://services.nvd.nist.gov/rest/json/cves/2.0/
NVD_API_KEY=
NVD_MAX_RETRIES=5
NVD_RETRY_DELAY_SECONDS=10

# CVE 自動匯入排程器配置
# 設為 false 時將禁用自動排程匯入 (需手動執行: docker compose exec server secra import)
IMPORT_ENABLED=true

# 匯入排程 (使用 Cron 格式，支援秒欄位)
# 格式: 秒 分 時 日 月 週
# 預設: "0 0 * * * *" 表示每小時的第 0 分鐘執行
# 範例:
#   "0 0 * * * *"      - 每小時執行 (預設)
#   "0 0 0 * * *"      - 每天午夜執行
#   "0 0 */6 * * *"    - 每 6 小時執行
#   "0 30 2 * * *"     - 每天凌晨 2:30 執行
IMPORT_SCHEDULE=0 0 * * * *

# 郵件通知配置 (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@secra.local
SMTP_ENCRYPTION=STARTTLS # Options: SSL, STARTTLS, NONE

# 預設管理員帳號配置
# 首次啟動時，如果資料庫中沒有任何使用者，系統會自動建立此管理員帳號
SECRA_ADMIN_USER=admin
SECRA_ADMIN_PWD=admin

