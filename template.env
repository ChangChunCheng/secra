# gRPC 服務監聽的本地位址
GRPC_PORT=:50051

# HTTP REST API 監聽位址（若有啟用 RESTful 服務）
HTTP_PORT=:8080

JWT_SECRET=secret

# PostgreSQL DSN：與 docker-compose 中的 postgres 容器一致
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/secra?sslmode=disable

NVD_URL_V1=https://nvd.nist.gov/feeds/json/cve/1.1/
NVD_URL_V2=https://services.nvd.nist.gov/rest/json/cves/2.0/

NVD_API_KEY=

# NVD API Retry Settings
NVD_MAX_RETRIES=3
NVD_RETRY_DELAY_SECONDS=5
