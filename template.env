# gRPC 服務監聽的本地位址
GRPC_PORT=:50051

# HTTP REST API 監聽位址
HTTP_PORT=:8081

# JWT 認證密鑰
JWT_SECRET=super-secret-key

# PostgreSQL DSN
POSTGRES_DSN=postgres://postgres:postgres@db:5432/secra?sslmode=disable

# NVD API 配置
NVD_URL_V1=https://nvd.nist.gov/feeds/json/cve/1.1/
NVD_URL_V2=https://services.nvd.nist.gov/rest/json/cves/2.0/
NVD_API_KEY=
NVD_MAX_RETRIES=5
NVD_RETRY_DELAY_SECONDS=10

# 郵件通知配置 (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@secra.local
SMTP_ENCRYPTION=STARTTLS # Options: SSL, STARTTLS, NONE

# 預設管理員帳號配置
# 首次啟動時，如果資料庫中沒有任何使用者，系統會自動建立此管理員帳號
SECRA_ADMIN_USER=admin
SECRA_ADMIN_PWD=admin

